# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (Free)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/linkcortexa

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Free Threat Intelligence APIs
VIRUSTOTAL_API_KEY=your_virustotal_free_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_free_api_key
IPINFO_TOKEN=your_ipinfo_free_token
